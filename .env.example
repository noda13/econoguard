# Database
DATABASE_URL="file:./dev.db"

# LLM Providers (at least one required for summarization/risk assessment)
# Gemini (recommended - free tier: 15 RPM, 1500 RPD)
GEMINI_API_KEY=
# Ollama (local - completely free, no rate limits)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# News API (optional)
NEWSAPI_KEY=

# FRED API
FRED_API_KEY=

# Open Exchange Rates (optional)
OPENEXCHANGERATES_APP_ID=

# Server
PORT=8901
NODE_ENV=development
TZ=Asia/Tokyo
